@page "/services"
@using Postgrest.Models
@using Supabase
@inject Supabase.Client supabase
@using Microsoft.VisualBasic

@using Roadfix2.Services
@using System.ComponentModel.DataAnnotations.Schema


<PageTitle>Order Services - RoadFix</PageTitle>

<div class="container my-5">
    <h1 class="text-center mb-4">Request Road Repair Services</h1>
    <p class="text-center mb-5">Fill out the form below to request pothole detection and repair services. We'll get back to you within 24 hours.</p>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <EditForm Model="@recOrder" OnValidSubmit="LogOrder" FormName="orderForm">
                            <DataAnnotationsValidator />
                        <!--<<div class="mb-3">
                            <label for="name" class="form-label">Full Name *</label>
                            <input type="text" class="form-control" id="name" required>
                        </div>
                            
                        div class="mb-3">
                            <label for="email" class="form-label">Email Address *</label>
                            <input type="email" class="form-control" id="email" required>
                        </div>-->

                        <div class="mb-3">
                            <label for="phone" class="form-label">Phone Number *</label>
                            <InputText id="phone" type="tel" @bind-Value="recOrder.phone" placeholder="081-234-5678"  required/> 
                            <ValidationMessage For="@(() =>recOrder.phone)" />
                        </div>

                        <div class="mb-3">
                            
                            <InputText type="text" @bind-Value="recOrder.Street"class="form-control" id="address" placeholder="123 Main St" required/>
                            <label for="address" class="form-label">Street Address *</label>
                            <ValidationMessage For="@(() => recOrder.Street)"/>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="city" class="form-label">City *</label>
                                <InputText type="text" @bind-Value="recOrder.City" class="form-control" id="city" required />
                                
                                <ValidationMessage For="@(() => recOrder.City)"/>
                                
                            </div>
                            <div class="col-md-3 mb-3">
                                <label for="state" class="form-label">Province *</label>
                                <InputText type="text" @bind-Value="recOrder.Province" class="form-control" id="state" required />
                                <ValidationMessage For="@(() => recOrder.Province)"/>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label for="zip" class="form-label">ZIP Code *</label>
                                <InputText type="text" @bind-Value="recOrder.ZipCode" class="form-control" id="zip" required />
                                <ValidationMessage For="@(() => recOrder.ZipCode)"/>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="serviceType" class="form-label">Service Type *</label>
                            <InputSelect @bind-Value="recOrder.Service_Type" class="form-select" id="serviceType" required>
                                <option value="">Select a service</option>
                                <option value="detection">Pothole Detection Only</option>
                                <option value="repair">Pothole Repair</option>
                                <option value="assessment">Road Assessment</option>
                                <option value="emergency">Emergency Repair (24/7)</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => recOrder.Service_Type)"/>
                        </div>

                        <div class="mb-3">
                            <label for="description" class="form-label">Description of Issue</label>
                            <InputTextArea @bind-Value="recOrder.issueDescription" class="form-control" id="description" rows="4" placeholder="Please describe the location, size, and severity of the potholes or road issues..." />
                            
                            <ValidationMessage For="@(() => recOrder.issueDescription)"/>
                        </div>

                <!--      <div class="mb-3">
                            <label for="urgency" class="form-label">Urgency Level</label>
                            <select class="form-select" id="urgency">
                                <option value="normal">Normal (within 1-2 weeks)</option>
                                <option value="urgent">Urgent (within 3-5 days)</option>
                                <option value="emergency">Emergency (same day if possible)</option>
                            </select>
                        </div>
-->
                        <div class="mb-3 form-check">
                            <InputCheckbox @bind-Value="recOrder.Insurance" class="form-check-input" id="insurance" />
                            <label class="form-check-label" for="insurance">
                                This is for insurance claim purposes
                            </label>
                            
                            <ValidationMessage For="@(() => recOrder.Insurance)"/>
                        </div>

                        <div class="mb-3 form-check">
                            <InputCheckbox @bind-Value="recOrder.newsletter" class="form-check-input" id="newsletter" />
                            <label class="form-check-label" for="newsletter">
                                Subscribe to our newsletter for road safety tips and updates
                            </label>
                            <ValidationMessage For="@(() => recOrder.newsletter)"/>
                        </div>

                        <div class="text-center">
                            <NavLink href="/dashboard" class="btn btn-primary btn-lg me-3">Submit Request</NavLink>
                            <NavLink href="/dashboard" class="btn btn-outline-secondary btn-lg">Back to Home</NavLink>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

    </div>

    <section id="contact" class="text-center">
        <h2 class="mb-4">Contact Us Today</h2>
        <p class="mb-4">Ready to fix those potholes? Get in touch for a free assessment and quote.</p>
        <div class="row">
            <div class="col-md-4">
                <i class="bi bi-telephone display-6 text-primary mb-2"></i>
                <h5>Call Us</h5>
                <p>(555) 123-ROAD</p>
            </div>
            <div class="col-md-4">
                <i class="bi bi-envelope display-6 text-primary mb-2"></i>
                <h5>Email Us</h5>
                <p>info@roadsfix.com</p>
            </div>
            <div class="col-md-4">
                <i class="bi bi-geo-alt display-6 text-primary mb-2"></i>
                <h5>Visit Us</h5>
                <p>123 Road Way<br>City, State 12345</p>
            </div>
        </div>
    </section>
</div>
@code {
    private string Name = string.Empty;
    private string CellNumber = string.Empty;

    private String Address = string.Empty;

    [SupplyParameterFromForm] 

    private recordOrder recOrder {get; set;} = new recordOrder ();

    private async Task LogOrder(){
            var model = new Order
            {
                Adress = recOrder.Adress,
                Service_Type = recOrder.Service_Type,
                issueDescription = recOrder.issueDescription,
                Insurance = recOrder.Insurance
                };
                 await supabase.From<Order>().Insert(model);

    }

   public class recordOrder(){
        public string FirstName { get; set; } = string.Empty;
        public string phone { get; set; } = string.Empty; 

        public string Street {get; set;} = string.Empty;
        public string City {get; set;} = string.Empty;

        public string Province {get; set;} = string.Empty;

        public string ZipCode {get; set;} = string.Empty;
        public string Adress => $"{Street},{City},{Province},{ZipCode}".Trim(',');

        public string Service_Type {get; set;} = string.Empty;
        public string issueDescription {get; set;} = string.Empty;

        public bool Insurance {get; set;} = false;
        public bool newsletter {get; set;} = false;

    }
    [Table("Order")]
    class Order :BaseModel{
        [Column("Adress")]
        public string Adress {get; set;} = string.Empty;

        [Column("ServiceType")]
        public string Service_Type {get; set;} = string.Empty;

        [Column("issueDescription")]
        public string issueDescription {get; set;} = string.Empty;

        [Column("insurance")]
        public bool Insurance {get; set;} = false;
        
    }


}